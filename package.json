{
  "name": "labdeck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:backend": "node build-backend.mjs && pkg dist-backend/labdeck-backend.cjs --targets node20-win-x64 --output src-tauri/binaries/labdeck-backend-x86_64-pc-windows-msvc.exe && node scripts/copy-release-sidecar.mjs",
    "tauri:build": "npm run build:backend && tauri build",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm run build:backend && tauri dev",
    "release:local": "npm run build:backend && tauri build && powershell -ExecutionPolicy Bypass -File scripts/copy-release-sidecar.ps1",
    "dev:live": "node scripts/dev-live.mjs"
  },
  "dependencies": {
    "@tauri-apps/plugin-shell": "^2.3.5",
    "axios": "^1.16.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vite": "^7.3.3"
  }
}
