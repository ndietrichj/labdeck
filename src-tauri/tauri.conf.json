{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LabDeck",
  "version": "1.0.0",
  "identifier": "com.labdeck.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LabDeck",
        "width": 1600,
        "height": 1000,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "../binaries/labdeck-backend"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}

